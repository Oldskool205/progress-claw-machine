# Supabase Cloud Integration (Phase A)
SUPABASE_URL=
SUPABASE_KEY=

# Optional settings
CLAW_MACHINE_NAME=Progress Claw Machine
CLAW_ARDUINO_TRANSPORT=gpio
CLAW_START_GPIO=17
CLAW_GRABBER_POWER_GPIOS=22,23,24
CLAW_READY_DURATION_SECONDS=3
CLAW_GRABBER_START_SECONDS=1
SUPABASE_MACHINE_STATUS_TABLE=machine_status
SUPABASE_RETRY_SECONDS=30
SUPABASE_SYNC_INTERVAL_SECONDS=60

# Bounded read-only analytics history (resets when the dashboard restarts).
CLAW_ANALYTICS_MAX_EVENTS=1000

# Player photos are private runtime data. Training archive is disabled unless
# local consent and private retention/storage procedures are in place.
CLAW_YOLO_ARCHIVE_PLAYER_PHOTOS=0

# Keep mock unless the reviewed helper and sudoers rule are installed and a
# supervised live activation has been explicitly approved.
PROGRESS_CLAW_WIFI_MODE=mock
PROGRESS_CLAW_WIFI_HELPER=/usr/local/sbin/progress-claw-wifi

# Phase 5 admin authentication (set locally; never commit real values)
PROGRESS_CLAW_ADMIN_PIN=
PROGRESS_CLAW_SECRET_KEY=
PROGRESS_CLAW_ADMIN_SESSION_SECONDS=300
# Optional; defaults to $XDG_RUNTIME_DIR/progress-claw/kiosk-exit-request
PROGRESS_CLAW_KIOSK_EXIT_FILE=
PROGRESS_CLAW_POWER_MODE=mock
PROGRESS_CLAW_POWER_HELPER=/usr/local/sbin/progress-claw-power
