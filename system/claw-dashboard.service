[Unit]
Description=Progress Claw OS machine dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=araya
Group=araya
WorkingDirectory=/home/araya/Projects/Progress-Claw-OS
EnvironmentFile=-/home/araya/Projects/Progress-Claw-OS/.env
Environment=PYTHONUNBUFFERED=1
Environment=CLAW_ARDUINO_TRANSPORT=gpio
Environment=GPIOZERO_PIN_FACTORY=rpigpio
ExecStart=/home/araya/Projects/Progress-Claw-OS/.venv/bin/python /home/araya/Projects/Progress-Claw-OS/main.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
